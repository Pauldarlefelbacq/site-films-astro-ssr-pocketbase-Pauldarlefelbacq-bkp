---
import { Debug } from "astro:components";
import Layout from "../../layouts/Layout.astro";
import type { FilmResponse, PersonneResponse, RoleResponse } from "../../pocketbase-types";
import LinkListeFilms from "../../components/LinkListeFilms.astro";
import LinkFilms from "../../components/LinkFilms.astro";
export const prerender = false;

const { id, nom_slug } = Astro.params;
const personne = await Astro.locals.pb.collection<PersonneResponse<{
  role_via_scenariste: FilmResponse[];
  role_via_producteur: FilmResponse[];
  role_via_realisateur: FilmResponse[];
  role_via_acteur : RoleResponse< {film: FilmResponse}>[];
}>>("personne").getOne(id, {
  expand:
    "role_via_producteur,role_via_realisateur,role_via_scenariste,role_via_acteur,role_via_acteur.film",
});
const isLoggedIn = Astro.locals.pb.authStore.isValid;

const displayName = personne.prenom
  ? `${personne.prenom} ${personne.nom ?? ""}`.trim()
  : personne.nom || "Personne";

const pageTitle = `${displayName} - Personne`;
const birthDate = personne.date_naissance
  ? new Date(personne.date_naissance).toLocaleDateString("fr-FR")
  : "Non specifiee";
const deathDate = personne.date_deces
  ? new Date(personne.date_deces).toLocaleDateString("fr-FR")
  : "Non specifiee";

let age = null;
if (personne.date_naissance) {
  const birth = new Date(personne.date_naissance);
  const endDate = personne.date_deces
    ? new Date(personne.date_deces)
    : new Date();
  age = endDate.getFullYear() - birth.getFullYear();
  const monthDiff = endDate.getMonth() - birth.getMonth();
  if (
    monthDiff < 0 ||
    (monthDiff === 0 && endDate.getDate() < birth.getDate())
  ) {
    age--;
  }
}
---

<Layout pageTitle={pageTitle}>
  <div>
    <div>
      <h1>{displayName}</h1>
      <p>
        {personne.profession?.join(", ") || "Profession non specifiee"}
      </p>
    </div>
    {isLoggedIn && <a href={`/personnes/edit/${id}-${nom_slug}`}>Editer</a>}
  </div>

  <div>
    <div>
      <p>Naissance</p>
      <p>{birthDate}</p>
    </div>
    <div>
      <p>Deces</p>
      <p>{deathDate}</p>
    </div>
    <div>
      <p>Age</p>
      <p>{age ?? "Non specifie"}</p>
    </div>
    <div>
      <p>Film comme producteur</p>
      <LinkListeFilms films={personne.expand?.role_via_producteur || []} />
    </div>
    <div>
      <p>Film comme realisateur</p>
      <LinkListeFilms films={personne.expand?.role_via_realisateur || []} />
  </div>
    <div>
      <p>Film comme scenariste</p>
      <LinkListeFilms films={personne.expand?.role_via_scenariste || []} />
    </div>
    <div>
      <p>Films comme acteur</p>
      <ul>
        { personne.expand?.role_via_acteur?.map((role) =>
            <li>
              Joue le role de <strong>{role.nom}</strong> dans le film <LinkFilms film={ role.expand?.film } />
            </li> )}
      </ul>
    </div>

  <a href="/personnes"> Retour a la liste des personnes </a>

</Layout>
